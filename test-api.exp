#!/usr/bin/expect -f

set timeout 60
set password "35332280"
set host "192.168.31.19"
set user "shaw"

spawn ssh -t ${user}@${host}

expect {
    "password:" { send "${password}\r"; exp_continue }
    "$ " {}
}

send "cd ~/history-figure-guess\r"
expect "$ "

# 测试正确的 API 路由
send "curl -s -X POST http://localhost:18080/v1/game-sessions -H 'Content-Type: application/json' -d '{\"questionLimit\":20}'\r"
expect "$ "

send "curl -s http://localhost:18080/v1/game-sessions 2>&1\r"
expect "$ "

send "docker compose logs server --tail=10\r"
expect "$ "

send "exit\r"
expect eof