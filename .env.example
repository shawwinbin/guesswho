# API Configuration
# For H5: use relative path '' if backend is on same origin, or full URL
# For Weapp: must use HTTPS domain configured in miniprogram admin
API_BASE_URL=http://localhost:3000

# Voice Service (Baidu)
BAIDU_APP_KEY=your-app-key
BAIDU_SECRET_KEY=your-secret-key

# WeChat Miniprogram
WECHAT_APP_ID=your-app-id
WECHAT_APP_SECRET=your-app-secret