#!/usr/bin/expect -f

set timeout 120
set password "35332280"
set host "192.168.31.19"
set user "shaw"

spawn ssh -t ${user}@${host}

expect {
    "password:" { send "${password}\r"; exp_continue }
    "$ " {}
}

send "cd ~/history-figure-guess\r"
expect "$ "

# 发送正确的请求体
send "curl -s -X POST http://localhost:18080/v1/game-sessions -H 'Content-Type: application/json' -d '{\"questionLimit\":20,\"figureScope\":\"all\"}'\r"
expect "$ "

send "echo '---'\r"
expect "$ "

send "curl -s http://localhost:18080 2>&1 | head -5\r"
expect "$ "

send "docker compose ps\r"
expect "$ "

send "exit\r"
expect eof