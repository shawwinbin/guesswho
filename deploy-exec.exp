#!/usr/bin/expect -f

set timeout 400
set password "35332280"
set host "192.168.31.19"
set user "shaw"

spawn ssh ${user}@${host} "bash /tmp/deploy-setup.sh"

expect {
    "password:" {
        send "${password}\r"
        exp_continue
    }
    "password for shaw:" {
        send "${password}\r"
        exp_continue
    }
    eof {
        puts "\n部署脚本执行完毕"
    }
    timeout {
        puts "\n超时"
        exit 1
    }
}