#!/usr/bin/expect -f

set timeout 300
set password "35332280"
set host "192.168.31.19"
set user "shaw"

spawn ssh ${user}@${host}

expect {
    "password:" {
        send "${password}\r"
        exp_continue
    }
    "$ " {
        # 使用 home 目录，不需要 sudo
        send "mkdir -p ~/history-figure-guess\r"
    }
}

expect "$ "
send "rm -rf ~/history-figure-guess/*\r"

expect "$ "
send "tar -xzf /tmp/deploy-package.tar.gz -C ~/history-figure-guess/\r"

expect "$ "
send "cd ~/history-figure-guess\r"

expect "$ "
send "cat > .env << 'EOF'\nCORS_ORIGIN=http://192.168.31.19:18080\nVITE_API_BASE_URL=/v1\nDATABASE_URL=postgres://postgres:postgres@postgres:5432/history_figure_guess\nLLM_BASE_URL=https://api.openai.com/v1\nLLM_API_KEY=replace-me\nLLM_MODEL=gpt-4o-mini\nEOF\r"

expect "$ "
send "ls -la\r"

expect "$ "
send "docker compose down 2>/dev/null; docker compose up -d --build\r"

# 等待 docker 构建完成，可能需要较长时间
expect {
    -timeout 240
    -re "Building|Creating|Pull|Started|done|ready" {
        exp_continue
    }
    "$ " {
        puts "\n构建命令已完成"
    }
}

expect "$ "
send "docker compose ps\r"

expect "$ "
send "docker compose logs --tail=20\r"

expect "$ "
send "exit\r"

expect eof
puts "\n部署结束"