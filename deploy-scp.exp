#!/usr/bin/expect -f

set timeout 120
set password "35332280"
set host "192.168.31.19"
set user "shaw"

# 传输压缩包
spawn scp /Users/shaw/history-figure-guess/deploy-package.tar.gz ${user}@${host}:/tmp/

expect {
    "password:" {
        send "${password}\r"
        exp_continue
    }
    eof {}
    timeout {
        puts "传输超时"
        exit 1
    }
}

puts "压缩包传输完成"