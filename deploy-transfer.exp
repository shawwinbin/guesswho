#!/usr/bin/expect -f

set timeout 300
set password "35332280"
set host "192.168.31.19"
set user "shaw"

# 使用 rsync 传输文件
spawn rsync -avz --progress \
    --exclude 'node_modules' \
    --exclude '.git' \
    --exclude 'dist' \
    --exclude '.claude' \
    --exclude 'docs' \
    --exclude '*.log' \
    /Users/shaw/history-figure-guess/ \
    ${user}@${host}:/opt/history-figure-guess/

expect {
    "password:" {
        send "${password}\r"
        exp_continue
    }
    eof {
        puts "传输完成"
    }
    timeout {
        puts "传输超时"
        exit 1
    }
}