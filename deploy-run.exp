#!/usr/bin/expect -f

set timeout 300
set password "35332280"
set host "192.168.31.19"
set user "shaw"

spawn ssh ${user}@${host}

expect {
    "password:" {
        send "${password}\r"
        exp_continue
    }
    "$ " {
        send "sudo mkdir -p /opt/history-figure-guess && sudo chown shaw:shaw /opt/history-figure-guess\r"
    }
}

expect "$ "
send "rm -rf /opt/history-figure-guess/*\r"

expect "$ "
send "tar -xzf /tmp/deploy-package.tar.gz -C /opt/history-figure-guess/\r"

expect "$ "
send "cd /opt/history-figure-guess\r"

expect "$ "
send "cat > .env << 'EOF'\nCORS_ORIGIN=http://192.168.31.19:18080\nVITE_API_BASE_URL=/v1\nDATABASE_URL=postgres://postgres:postgres@postgres:5432/history_figure_guess\nLLM_BASE_URL=https://api.openai.com/v1\nLLM_API_KEY=replace-me\nLLM_MODEL=gpt-4o-mini\nEOF\r"

expect "$ "
send "docker compose down 2>/dev/null; docker compose up -d --build\r"

expect {
    -timeout 180
    "Creating" {
        exp_continue
    }
    "Building" {
        exp_continue
    }
    "Started" {
        exp_continue
    }
    "$ " {
        puts "\n部署完成"
    }
}

expect "$ "
send "docker compose ps\r"

expect "$ "
send "exit\r"

expect eof
puts "SSH 连接关闭"